# UYUM — Environment Template
# .env.local Vercel'de Environment Variables'a girer; bu dosya commit'lenir.

# === ZORUNLU (üretimde aktif) ===

# F3 İlk Ziyaret Rehberi — n8n webhook (üretim tek yolu)
VITE_N8N_F3_WEBHOOK_URL=

# === BUILD-TIME (runtime'a sızmaz, VITE_ prefix YOK) ===

# Google Places API — build-time tesis verisi için (scripts/fetch-places-cache.mjs)
# Vercel: Settings → Environment Variables → Production + Preview scope
# VITE_ prefix KESİNLİKLE YOK — bundle'a sızarsa güvenlik açığıdır.
GOOGLE_PLACES_API_KEY=

# === OPSİYONEL (Faz 6 sonrası, P1 stabilse) ===

# WF-02 anonim sorun bildirimi webhook
VITE_N8N_REPORT_ISSUE_WEBHOOK_URL=

# === ÜRETİMDE KULLANILMAZ ===

# Direkt OpenAI çağrısı sadece yerel geliştirme/debug için.
# Vercel Environment Variables'a EKLENMEZ. Bundle'a sızarsa
# güvenlik açığıdır. F3 üretiminde n8n workflow OpenAI'ı çağırır.
# VITE_OPENAI_KEY=
